# 推荐使用 DeepSeek 官方 API。Key 只配置在本机环境变量或 GitHub Secret。
AI_PROVIDER=auto
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com
AI_BATCH_SIZE=3
AI_RESUMMARIZE_EXISTING=0

# 可选的备用供应商。未配置任何 Key 时使用发布方公开摘要。
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# 可选。采集窗口和数量也可以在 config/sources.json 中设置。
COLLECT_LOOKBACK_DAYS=30
COLLECT_MAX_ARTICLES=36
HISTORY_MAX_ARTICLES=160
HISTORY_RETENTION_DAYS=365

# 可选。GDELT 容易触发限流，默认使用 Google News RSS + Bing News RSS。
ENABLE_GDELT=0

# 可选。集中反馈 Worker 的根地址及聚合接口。
FEEDBACK_API_URL=
FEEDBACK_AGGREGATE_URL=
FEEDBACK_AGGREGATE_TOKEN=
